{
  "name": "fermat",
  "version": "0.1.0",
  "description": "Fermat — the proof is no longer too large for the margin. AI-powered LaTeX editor for proving theorems.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "vite",
    "build": "vite build && electron-builder",
    "dist": "vite build && electron-builder --publish never",
    "lint": "eslint src/",
    "gen-icons": "node scripts/generate-icons.js"
  },
  "build": {
    "appId": "life.fermat.app",
    "productName": "Fermat",
    "asar": true,
    "directories": {
      "output": "release/"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/renderer/**/*",
      "public/**/*",
      ".claude/skills/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".claude/skills",
        "to": ".claude/skills",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "build/icon.png",
      "category": "Education"
    },
    "publish": null
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "electron-updater": "^6.1.7",
    "electron-store": "^8.2.0",
    "monaco-editor": "^0.47.0",
    "pdfjs-dist": "^4.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^41.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.4.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "wait-on": "^7.2.0"
  }
}
